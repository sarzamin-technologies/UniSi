# =====================================================================
# UniSi — environment variables
# Copy to .env (or .env.local for local dev) and fill in.
# =====================================================================

# --- App ---
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Generate with: openssl rand -hex 32
# Used both as iron-session cookie key AND as HKDF source for
# encrypting Agnic refresh tokens at rest in the database.
SESSION_SECRET=replace_me_with_64_hex_chars

# --- Agnic OAuth ---
# Register your app at https://app.agnic.ai/oauth-clients
# Required redirect URIs:
#   {NEXT_PUBLIC_APP_URL}/api/auth/callback
#   {NEXT_PUBLIC_APP_URL}/api/auth/popup-callback
#   {NEXT_PUBLIC_APP_URL}/api/auth/signer-callback
#   {NEXT_PUBLIC_APP_URL}/                       (top-up return)
AGNIC_OAUTH_CLIENT_ID=app_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_AGNIC_OAUTH_CLIENT_ID=app_xxxxxxxxxxxxxxxxxxxx

# Optional. Per the Agnic guide PKCE is sufficient for public clients, but
# if your registered OAuth client is confidential set the secret here and
# it will be sent in the token-exchange request.
AGNIC_OAUTH_CLIENT_SECRET=

# Apply for the Partner Program at https://app.agnic.ai/oauth-clients —
# Agnic returns the partner_xxx ID. Sent as X-Partner-Id on every gateway
# call for commission attribution. See:
#   https://docs.agnic.ai/docs/partner-program
AGNIC_PARTNER_ID=

AGNIC_API_BASE=https://api.agnic.ai
NEXT_PUBLIC_AGNIC_AUTH_URL=https://app.agnic.ai
NEXT_PUBLIC_AGNIC_TOPUP_URL=https://app.agnic.ai/topup

# --- Database ---
DATABASE_URL=postgres://unisi:unisi@localhost:5432/unisi

# --- Redis (BullMQ) ---
REDIS_URL=redis://localhost:6379

# --- Object storage (MinIO local, S3/R2 prod) ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=unisi
S3_ACCESS_KEY_ID=unisi
S3_SECRET_ACCESS_KEY=unisi-secret-key
S3_FORCE_PATH_STYLE=true

# --- Email (Resend in prod, Mailpit locally) ---
RESEND_API_KEY=
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM="UniSi <noreply@unisi.local>"

# --- Audit-trail signing (PAdES) ---
# PKCS#12 certificate used to digitally sign the audit-trail certificate PDF.
# Dev: run ./scripts/gen-signing-cert.sh to create a self-signed cert.
# Prod: use a CA-issued / organization certificate so readers trust it.
# If unset, the audit trail is still generated but left UNSIGNED.
# Local dev uses a file path; hosted platforms (Railway/Fly) should set the
# base64 of the .p12 instead (takes precedence over the path).
PLATFORM_SIGN_P12_PATH=
PLATFORM_SIGN_P12_BASE64=
PLATFORM_SIGN_P12_PASSPHRASE=
