{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [".env"],
  "globalEnv": [
    "NODE_ENV",
    "AGNIC_OAUTH_CLIENT_ID",
    "NEXT_PUBLIC_AGNIC_OAUTH_CLIENT_ID",
    "AGNIC_PARTNER_ID",
    "AGNIC_API_BASE",
    "NEXT_PUBLIC_AGNIC_AUTH_URL",
    "NEXT_PUBLIC_AGNIC_TOPUP_URL",
    "NEXT_PUBLIC_APP_URL",
    "SESSION_SECRET",
    "DATABASE_URL",
    "REDIS_URL",
    "S3_ENDPOINT",
    "S3_REGION",
    "S3_BUCKET",
    "S3_ACCESS_KEY_ID",
    "S3_SECRET_ACCESS_KEY",
    "RESEND_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
